# Server
PORT=5001
NODE_ENV=development

# Database (Railway or local)
DATABASE_URL=postgresql://user:password@host:5432/kpi_dashboard

# JWT — use a long random string in production
JWT_SECRET=your_jwt_secret_here

# QuickBooks Online OAuth2
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_ACCESS_TOKEN=
QBO_REFRESH_TOKEN=
QBO_REALM_ID=

# JobNimbus (direct REST API — replaces the old Zapier webhook)
JOBNIMBUS_API_KEY=
# Optional overrides:
# JOBNIMBUS_API_BASE=https://app.jobnimbus.com/api1
# JOBNIMBUS_SYNC_INTERVAL_MIN=15
